# ============================================================================
#  Bluesky Dog-Free Feed  Environment Variables
#  Copy this file to .env and fill in your values.
# ============================================================================

#  Required: Bluesky credentials 
# Your Bluesky handle (e.g. yourname.bsky.social)
BLUESKY_HANDLE=

# An App Password  generate one at:
#   Settings  Privacy and Security  App Passwords
BLUESKY_APP_PASSWORD=

#  Optional: Bluesky service URL 
# Only change this if you run a self-hosted PDS.
# BLUESKY_SERVICE=https://bsky.social

#  Optional: Feed tuning 
# Posts fetched per search query (max 100)
# POSTS_PER_QUERY=100

# Ignore posts older than this many hours
# MAX_POST_AGE_HOURS=48

# Number of posts in the final feed.json
# FEED_SIZE=50
